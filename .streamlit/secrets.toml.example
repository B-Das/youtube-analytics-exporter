# ============================================================
# Streamlit Cloud Secrets — Example Configuration
# ============================================================
# Copy the contents of THIS file into your Streamlit Cloud app's
# "Secrets" section (Settings → Secrets) after removing this header block.
#
# DO NOT commit this file with real credentials.
# This is a template only.
# ============================================================


# ----------------------------------------------------------
# Required: Your app's public Streamlit Cloud URL.
# Used to build the OAuth redirect URI automatically.
# Must end with a trailing slash.
# ----------------------------------------------------------
app_url = "https://youtube-analytics-exporter.streamlit.app/"


# ----------------------------------------------------------
# Required: Google OAuth 2.0 client credentials.
#
# Source: Google Cloud Console → APIs & Services → Credentials
# → Your OAuth 2.0 Client ID → Download JSON
#
# Paste the contents of client_secrets.json here as a TOML
# table under [client_secrets]. The keys must match exactly
# what Google provides in the downloaded JSON file.
#
# The structure below matches a "Web application" OAuth client.
# ----------------------------------------------------------
[client_secrets]
client_id     = "YOUR_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET"
project_id    = "your-gcp-project-id"
auth_uri      = "https://accounts.google.com/o/oauth2/auth"
token_uri     = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"

# Redirect URIs: must include your Streamlit Cloud URL.
# Also include localhost for local testing if desired.
redirect_uris = [
    "https://youtube-analytics-exporter.streamlit.app/",
    "http://localhost:8501/"
]

# JavaScript origins (optional but recommended)
javascript_origins = [
    "https://youtube-analytics-exporter.streamlit.app",
    "http://localhost:8501"
]
